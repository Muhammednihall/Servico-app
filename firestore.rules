rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Customer profiles
    match /customers/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Worker profiles
    match /workers/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Booking Requests
    match /booking_requests/{bookingId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.customerId || 
        request.auth.uid == resource.data.workerId ||
        request.auth.uid == request.resource.data.workerId
      );
    }

    // Notifications
    match /customer_notifications/{notificationId} {
      allow read, update: if isSignedIn() && request.auth.uid == resource.data.customerId;
      allow create: if isSignedIn(); // Allow apps to create if needed, or restrict to functions
    }

    match /worker_notifications/{notificationId} {
      allow read, update: if isSignedIn() && request.auth.uid == resource.data.workerId;
      allow create: if isSignedIn();
    }

    // Broadcasts
    match /broadcast_notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if false; // Only via Admin/Functions
    }

    // Public configurations
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; 
    }
    
    match /Locations/{locationId} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
